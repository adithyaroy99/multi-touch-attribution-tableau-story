    <worksheet name='Last Touch Channel Conversion'>
      <layout-options>
        <caption>
          <formatted-text>
            <run>User Conversion Rate for each Channel1.  The marks are labeled by User Conversion Rate and distinct count of User ID1. The data is filtered on Is Last Touch and Campaign. The Is Last Touch filter keeps 1. The Campaign filter keeps 6 of 6 members.
</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Observed user conversion rate by last-touch channel (user-level).</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>
Labels show conversion rate and distinct users (n).
Filters: </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Is Last Touch = 1</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>; Campaign defaults to </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>All</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>.&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Metric:</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> User Conversion Rate = COUNTD(IF [User Converted]=1 THEN [User ID] END) / COUNTD([User ID])</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='multi_touch_attribution_data' name='federated.1mprire1l5ndmp1aqkhgo01bt7it' />
          </datasources>
          <datasource-dependencies datasource='federated.1mprire1l5ndmp1aqkhgo01bt7it'>
            <column caption='Is Conversion' datatype='integer' name='[Calculation_1046805476478324736]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Conversion] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='User Converted' datatype='integer' name='[Calculation_1046805476478410753]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [User ID] : MAX([Calculation_1046805476478324736]) }' />
            </column>
            <column caption='Last Touch Time' datatype='datetime' name='[Calculation_1046805476484349959]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{ FIXED [User ID] : MAX([Timestamp]) }' />
            </column>
            <column caption='Is Last Touch' datatype='integer' name='[Calculation_1046805476484452360]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Timestamp] = [Calculation_1046805476484349959] THEN 1 ELSE 0 END' />
            </column>
            <column caption='User Conversion Rate' datatype='real' name='[Calculation_1132936819992403971]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD( IF [Calculation_1046805476478410753] = 1 THEN [User ID] END ) / COUNTD([User ID])' />
            </column>
            <column datatype='string' name='[Campaign]' role='dimension' type='nominal' />
            <column caption='Channel1' datatype='string' name='[Channel]' role='dimension' type='nominal' />
            <column datatype='string' name='[Conversion]' role='dimension' type='nominal' />
            <column caption='Timestamp1' datatype='datetime' name='[Timestamp]' role='dimension' type='ordinal' />
            <column caption='User ID1' datatype='integer' name='[User ID]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1046805476478410753]' derivation='Avg' name='[avg:Calculation_1046805476478410753:qk]' pivot='key' type='quantitative' />
            <column-instance column='[User ID]' derivation='CountD' name='[ctd:User ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1046805476484452360]' derivation='None' name='[none:Calculation_1046805476484452360:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Campaign]' derivation='None' name='[none:Campaign:nk]' pivot='key' type='nominal' />
            <column-instance column='[Channel]' derivation='None' name='[none:Channel:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1132936819992403971]' derivation='User' name='[usr:Calculation_1132936819992403971:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1mprire1l5ndmp1aqkhgo01bt7it].[none:Calculation_1046805476484452360:ok]'>
            <groupfilter function='member' level='[none:Calculation_1046805476484452360:ok]' member='1' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1mprire1l5ndmp1aqkhgo01bt7it].[none:Campaign:nk]'>
            <groupfilter function='level-members' level='[none:Campaign:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.1mprire1l5ndmp1aqkhgo01bt7it].[none:Channel:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.1mprire1l5ndmp1aqkhgo01bt7it].[avg:Calculation_1046805476478410753:qk]' shelf='rows' />
          </shelf-sorts>
