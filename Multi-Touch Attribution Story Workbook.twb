            <column>[federated.1mprire1l5ndmp1aqkhgo01bt7it].[none:Calculation_1046805476484452360:ok]</column>
            <column>[federated.1mprire1l5ndmp1aqkhgo01bt7it].[none:Campaign:nk]</column>
          </slices>
          <aggregation value='true' />
